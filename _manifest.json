{
  "manifest_version": 1,
  "name": "复读器插件|Repeater Plugin",
  "version": "1.0.0",
  "description": "当同一内容被超过两位不同用户连续发送时自动复读",
  "author": {
    "name": "MaiBot Community",
    "url": "https://github.com/MaiM-with-u"
  },
  "license": "GPL-v3.0-or-later",
  "host_application": {
    "min_version": "0.10.3"
  },
  "homepage_url": "https://github.com/MaiM-with-u",
  "repository_url": "https://github.com/MaiM-with-u",
  "keywords": [
    "repeater",
    "chat",
    "event",
    "group"
  ],
  "categories": [
    "Chat",
    "Interaction"
  ],
  "default_locale": "zh-CN",
  "locales_path": "_locales",
  "plugin_info": {
    "is_built_in": false,
    "plugin_type": "chat",
    "components": [
      {
        "type": "action",
        "name": "repeater_action",
        "description": "在满足条件时复读上一个人的发言"
      }
    ],
    "features": [
      "连续同内容检测",
      "仅统计非机器人用户",
      "超过两位不同用户触发复读",
      "每段内容最多复读一次"
    ]
  },
  "id": "MaiBot.Repeater"
}
